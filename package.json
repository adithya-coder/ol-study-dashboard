{
  "name": "ol-smart-study-dashboard",
  "version": "1.0.0",
  "description": "Offline-capable PWA study dashboard for Sri Lankan O/L 2026 exam preparation",
  "type": "module",
  "scripts": {
    "server": "nodemon server.js",
    "client": "serve . -p 3000",
    "dev": "concurrently \"npm run server\" \"npm run client\""
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "fast-check": "^4.1.1",
    "nodemon": "^3.1.14",
    "vitest": "^3.1.4"
  },
  "private": true,
  "dependencies": {
    "@upstash/redis": "^1.38.0",
    "@vercel/blob": "^2.5.0",
    "@vercel/kv": "^3.0.0",
    "chart.js": "^4.5.1",
    "cors": "^2.8.6",
    "express": "^5.2.1"
  }
}
